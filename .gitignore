# Ignore everything by default
*

# Whitelist root-level files
!/.gitignore
!/README.md
!/paper.qmd
!/references.bib
!/apa.csl

# Whitelist scripts directory and specific file types
!/badranseq_joss_figures/
!/badranseq_joss_figures/scripts/
!/badranseq_joss_figures/scripts/*.qmd
!/badranseq_joss_figures/scripts/*.R

# Explicit ignores (even within whitelisted dirs)
badranseq_joss_figures/scripts/*.html
badranseq_joss_figures/write/
AGENTS.md

# Ignore Quarto/R build artifacts
*.pdf
*.tex
.quarto/
paper_files/
